# =============================================================================
# Personal CRM — example environment file
# =============================================================================
# Copy this file to `.env.local` for local development and fill in real values.
# Real secrets MUST NOT be committed. Every variable used by the app must be
# listed here so reviewers and deployment platforms know what to provide.
# -----------------------------------------------------------------------------

# Public base URL of the deployed app. Used for absolute URLs (emails, OG tags,
# share links, etc.). Safe to expose to the browser (NEXT_PUBLIC_ prefix).
# Example (prod): https://crm.example.com
NEXT_PUBLIC_APP_URL=

# Connection string for the primary relational database. Server-only; never
# expose this to the browser. Will be wired up once persistence is added.
# Example: postgres://user:password@host:5432/personal_crm
DATABASE_URL=
