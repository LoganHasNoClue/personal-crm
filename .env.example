# =============================================================================
# Personal CRM — example environment file
# =============================================================================
# Copy this file to `.env.local` for local development and fill in real values.
# Real secrets MUST NOT be committed. Every variable used by the app must be
# listed here so reviewers and deployment platforms know what to provide.
# -----------------------------------------------------------------------------

# Public base URL of the deployed app. Used for absolute URLs (emails, OG tags,
# share links, etc.). Safe to expose to the browser (NEXT_PUBLIC_ prefix).
# Example (prod): https://crm.example.com
NEXT_PUBLIC_APP_URL=

# Connection string for the primary relational database. Server-only; never
# expose this to the browser. Will be wired up once persistence is added.
# Example: postgres://user:password@host:5432/personal_crm
DATABASE_URL=

# -----------------------------------------------------------------------------
# Apple MapKit JS
# -----------------------------------------------------------------------------
# Required for the /map page to render Apple Maps. When any of these are
# missing, the map page degrades to a "configure credentials" empty state and
# the rest of the app continues to work.
#
# Get these from https://developer.apple.com/account → Certificates, IDs &
# Profiles → Keys → "+ Create a Key" → enable "MapKit JS" → register a Maps ID.

# Your 10-character Apple Developer Team ID. Used as the JWT issuer.
MAPKIT_TEAM_ID=

# 10-character Key ID of the MapKit JS-enabled key you created above.
MAPKIT_KEY_ID=

# Contents of the .p8 private key file. Either paste the multi-line PEM as-is
# (wrap in quotes), or paste a single-line value with `\n` between lines.
# Example (single-line):
# MAPKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAg...\n-----END PRIVATE KEY-----\n"
MAPKIT_PRIVATE_KEY=
